# ============================================
# AUTO-CODER ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your keys
# ============================================

# --- AI MODELS ---
# Anthropic (Claude) - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT-4o) - https://platform.openai.com
OPENAI_API_KEY=sk-your-key-here

# DeepSeek - https://platform.deepseek.com
DEEPSEEK_API_KEY=your-key-here

# Fireworks AI (fast inference for autocomplete) - https://fireworks.ai
FIREWORKS_API_KEY=your-key-here

# --- CODE EXECUTION SANDBOX ---
# E2B Sandbox - https://e2b.dev
E2B_API_KEY=your-key-here

# --- DATABASE ---
# Supabase (cloud sync) - https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- AUTH ---
# Clerk - https://clerk.dev
# Leave blank (or use real keys from dashboard.clerk.com) for local /dashboard + /api/agent without sign-in.
# Template values like "your-key-here" are treated as disabled so sign-in does not hang on invalid keys.
# Force-disable Clerk in the browser bundle: NEXT_PUBLIC_CLERK_DISABLED=1
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_SECRET_KEY=sk_test_your-key-here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- PAYMENTS ---
# Stripe - https://stripe.com
STRIPE_SECRET_KEY=sk_test_your-key-here
# Dashboard → Developers → Webhooks → endpoint → Signing secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_your-key-here
# Subscribe the webhook URL (POST /api/stripe/webhook) to these event types:
# checkout.session.completed, checkout.session.async_payment_succeeded, checkout.session.async_payment_failed,
# customer.subscription.created, customer.subscription.updated, customer.subscription.deleted,
# invoice.paid, invoice.payment_failed
# Sync Clerk privateMetadata from Stripe (checkout + subscriptions). Requires client_reference_id or metadata.clerk_user_id on Checkout; webhooks above must be enabled. Set 0 to disable.
# STRIPE_SYNC_CLERK_METADATA=1
# Optional — only if you add Stripe.js on the client; hosted Checkout + webhooks work without this
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Stripe Price IDs (create these in Stripe dashboard) — used by POST /api/stripe/checkout + landing "Subscribe"
STRIPE_PRO_PRICE_ID=price_your-id-here
STRIPE_TEAM_PRICE_ID=price_your-id-here
# Stripe Tax (optional): after enabling Tax in Dashboard + tax behavior on Prices, set 1 for automatic_tax, required billing address, and tax_id collection on Checkout
# STRIPE_CHECKOUT_AUTOMATIC_TAX=1

# Customer Portal: enable under Stripe Dashboard → Billing → Customer portal (POST /api/stripe/portal)
# Billing routes rate limit (checkout + portal), per Clerk user, in-process. 0 = disable.
# BILLING_API_WINDOW_MS=60000
# BILLING_API_MAX_PER_WINDOW=15

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- WEB API GUARDS (POST /api/agent) ---
# Sliding window per signed-in user. In-memory: one Node instance only; use Redis for multi-instance.
AGENT_API_WINDOW_MS=60000
AGENT_API_MAX_PER_WINDOW=30
# Daily cap per user (UTC day). 0 = disabled (good for local dev).
AGENT_API_DAILY_MAX=0
# When 1/true/yes: POST /api/agent requires Clerk publicMetadata stripeEntitlementTier=pro (set by Stripe subscription webhooks).
# AGENT_API_REQUIRES_PRO=0
# Log Clerk sessionId / orgId on /api/agent when `1` or `true` (use in staging; mind PII in logs).
# AGENT_API_DEBUG=0

# --- UPSTASH REDIS (optional — shared rate limits across web instances) ---
# https://upstash.com — create a Redis database and paste REST credentials.
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxx

# --- GITHUB INTEGRATION (for CI/CD agent) ---
GITHUB_APP_ID=your-app-id
GITHUB_APP_PRIVATE_KEY=your-private-key
GITHUB_WEBHOOK_SECRET=your-webhook-secret
