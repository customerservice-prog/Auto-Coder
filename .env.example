# ============================================
# AUTO-CODER ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your keys
# ============================================

# --- AI MODELS ---
# Anthropic (Claude) - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT-4o) - https://platform.openai.com
OPENAI_API_KEY=sk-your-key-here

# DeepSeek - https://platform.deepseek.com
DEEPSEEK_API_KEY=your-key-here

# Fireworks AI (fast inference for autocomplete) - https://fireworks.ai
FIREWORKS_API_KEY=your-key-here

# --- CODE EXECUTION SANDBOX ---
# E2B Sandbox - https://e2b.dev
E2B_API_KEY=your-key-here

# --- DATABASE ---
# Supabase (cloud sync) - https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- AUTH ---
# Clerk - https://clerk.dev
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_SECRET_KEY=sk_test_your-key-here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- PAYMENTS ---
# Stripe - https://stripe.com
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Stripe Price IDs (create these in Stripe dashboard)
STRIPE_PRO_PRICE_ID=price_your-id-here
STRIPE_TEAM_PRICE_ID=price_your-id-here

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- GITHUB INTEGRATION (for CI/CD agent) ---
GITHUB_APP_ID=your-app-id
GITHUB_APP_PRIVATE_KEY=your-private-key
GITHUB_WEBHOOK_SECRET=your-webhook-secret
