{
  "name": "desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "predev": "tsc -p tsconfig.electron.json && tsc --noEmit",
    "dev": "concurrently -n vite,tsc,electron \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "build:electron": "electron-builder",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "tsc --noEmit",
    "test": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@auto-coder/ai-core": "workspace:*",
    "@auto-coder/indexer": "workspace:*",
    "@monaco-editor/react": "^4.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ai": "^4.0.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "xterm-addon-search": "^0.13.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "monaco-editor": "~0.50.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "concurrently": "^8.0.0",
    "vite": "^5.2.0",
    "typescript": "^5.4.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.0.0"
  },
  "build": {
    "appId": "com.autocoder.ide",
    "productName": "Auto-Coder",
    "directories": {
      "output": "release"
    },
    "files": ["dist/**/*", "node_modules/**/*"],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  }
}
