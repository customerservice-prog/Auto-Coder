# Opened in the system browser from Help → Sign in / activity bar account icon.
# Defaults to http://localhost:3000/sign-in when unset.
# VITE_WEB_SIGN_IN_URL=https://your-domain/sign-in

# Vite dev server port (renderer). Electron main reads this; must match apps/desktop/vite.config.ts server.port.
# VITE_DEV_PORT=5173
